{
  "id": "remote_library_client",
  "name": "Remote Library Client",
  "version": "0.1.3",
  "private": false,
  "nav": { "label": "Remote Client", "screen": "remote-library-client" },
  "screen": "screen.html",
  "script": "screen.js",
  "routes": "routes.py",
  "standards": ["capability-pipelines.v1", "plugin-runtime-idempotent.v1"],
  "capabilities": {
    "library": {
      "roles": ["provider"],
      "operations": ["query-page", "query-artists", "query-stats", "tuning-names", "get-art", "sync-song"],
      "description": "Registers configured Remote Library Server URLs as browsable library providers with remote metadata, artwork, and song sync.",
      "mode": "active",
      "compatibility": "none",
      "ownership": "multi-provider",
      "safety": "safe",
      "version": 1
    }
  }
}